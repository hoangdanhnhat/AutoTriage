# Copy to .env and fill in values
POSTGRES_USER=forensics
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=forensics_db
DATABASE_URL=postgresql+asyncpg://forensics:changeme_strong_password@db:5432/forensics_db

REDIS_URL=redis://redis:6379/0

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_generate_a_real_secret_key
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Path to ansible SSH private key (mounted into backend container)
ANSIBLE_SSH_KEY_PATH=/root/.ssh/ansible
# Default SSH user for Linux nodes when inventory does not set ansible_user
LINUX_ANSIBLE_USER=ubuntu
# Sudo/become password for Linux nodes. Leave empty if using passwordless sudo.
LINUX_BECOME_PASSWORD=
# Path on host to mount (change to your actual key path)
HOST_ANSIBLE_KEY_PATH=/home/ratatoui1e/.ssh/ansible

# Absolute path for storing fetched triage artifacts
# This path exists inside the backend container
ARTIFACTS_DIR=/app/artifacts

# First-run admin account seed (only used on first startup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_admin_password
ADMIN_EMAIL=admin@localhost
